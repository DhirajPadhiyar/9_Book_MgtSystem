@model _9_Book_MgtSystem.Models.Bookk

<form asp-action="InsertData" method="post">
    <div class="form-group">
        <label asp-for="BookkName"></label>
        <input asp-for="BookkName" class="form-control" />
        <span asp-validation-for="BookkName" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Author"></label>
        <input asp-for="Author" class="form-control" />
        <span asp-validation-for="Author" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Price"></label>
        <input asp-for="Price" class="form-control" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>
    <hr /> 
    <button type="submit" class="btn btn-primary">Insert Book</button>
    <a asp-action="DisplayData" class="btn btn-secondary">View Books</a>
</form>