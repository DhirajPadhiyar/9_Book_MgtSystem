@model List<_9_Book_MgtSystem.Models.Bookk>

<div class=" mx-auto col-md-6">
    <table class="table table-striped table-bordered table-hover ">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Title</th>
            <th>Author</th>
            <th>Price</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.BookkId</td>
                <td>@book.BookkName</td>
                <td>@book.Author</td>
                <td>@book.Price</td>
            </tr>
        }
    </tbody>
    </table>
    </div>

